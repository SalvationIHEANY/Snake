// EN MyKeyAdapter — añadir controles WASD para jugador 2
case KeyEvent.VK_W:
    if (snake2.getDirection() != Direction.DOWN && !turning) {
        snake2.setDirection(Direction.UP); turning = true;
    }
    break;
case KeyEvent.VK_S:
    if (snake2.getDirection() != Direction.UP && !turning) {
        snake2.setDirection(Direction.DOWN); turning = true;
    }
    break;
case KeyEvent.VK_A:
    if (snake2.getDirection() != Direction.RIGHT && !turning) {
