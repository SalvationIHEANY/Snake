## 20. 🛠️ ConfigDialog mejorado (validación + cancel)

**Cuándo:** "mejora la configuración" / "valida el nombre" / "botón cancelar"

```java
// REEMPLAZAR ConfigDialog.java completo
package com.mycompany.snakeexam2;

import javax.swing.*;
import java.awt.*;

public class ConfigDialog extends JDialog {
    public ConfigDialog(Frame parent, boolean modal) {
        super(parent, "Configuration", modal);

        JPanel panel = new JPanel(new GridLayout(3, 2, 10, 10));
        panel.setBorder(BorderFactory.createEmptyBorder(10, 10, 10, 10));

        // Nombre
        panel.add(new JLabel("Player name:"));
        JTextField nameField = new JTextField(
            Config.playerName != null ? Config.playerName : ""
        );
        panel.add(nameField);

        // Nivel
        panel.add(new JLabel("Level:"));
        JComboBox<String> levelBox = new JComboBox<>(
            new String[]{"Easy", "Normal", "Hard", "Extreme"}
        );
        levelBox.setSelectedIndex(Config.level);
        panel.add(levelBox);

        // Botones
        JButton okBtn = new JButton("OK");
        JButton cancelBtn = new JButton("Cancel");

        okBtn.addActionListener(e -> {
            String name = nameField.getText().trim();
            if (name.isEmpty()) {
                JOptionPane.showMessageDialog(this,
                    "Please enter a name", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            }
            Config.playerName = name;
            Config.level = levelBox.getSelectedIndex();
            dispose();
        });

        cancelBtn.addActionListener(e -> dispose());

        panel.add(okBtn);
        panel.add(cancelBtn);

        setContentPane(panel);
        pack();
        setLocationRelativeTo(parent);
    }
}
```

