## 14. 📐 Grid visual (cuadrícula de fondo)

**Cuándo:** "dibuja la cuadrícula" / "mejora visual"

```java
// EN Board.java — nuevo método
private void drawGrid(Graphics g) {
    int cellW = getWidth() / NUM_COLS;
    int cellH = getHeight() / NUM_ROWS;
    g.setColor(new Color(230, 230, 230)); // gris muy claro
    // Líneas verticales
    for (int c = 0; c <= NUM_COLS; c++) {
        g.drawLine(c * cellW, 0, c * cellW, NUM_ROWS * cellH);
    }
    // Líneas horizontales
    for (int r = 0; r <= NUM_ROWS; r++) {
        g.drawLine(0, r * cellH, NUM_COLS * cellW, r * cellH);
    }
}

// EN paintComponent() — llamar ANTES de pintar snake y food
@Override
protected void paintComponent(Graphics g) {
    super.paintComponent(g);
    // Fondo blanco
    g.setColor(Color.WHITE);
    g.fillRect(0, 0, getWidth(), getHeight());
    drawGrid(g);           // cuadrícula
    drawBlackBorder(g);    // borde
    if (snake != null) {
        snake.paint(g, getWidth() / NUM_COLS, getHeight() / NUM_ROWS);
        food.paint(g, getWidth() / NUM_COLS, getHeight() / NUM_ROWS);
        if (gameOver) printGameOver(g);
    }
    Toolkit.getDefaultToolkit().sync();
}
