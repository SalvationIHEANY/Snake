// NUEVO ENUM: GameState.java
package com.mycompany.snakeexam2;

public enum GameState {
    MENU,       // Pantalla inicial, esperando "Start"
    PLAYING,    // Juego en marcha
    PAUSED,     // Juego pausado
    GAME_OVER   // Juego terminado
}

// EN Board.java — reemplazar boolean gameOver y boolean paused
private GameState state = GameState.MENU;

// EN tick() — solo ejecutar si estamos jugando
private void tick() {
    if (state != GameState.PLAYING) return;
    // ... resto igual ...
}

// EN MyKeyAdapter — respetar el estado
@Override
public void keyPressed(KeyEvent e) {
    if (state == GameState.GAME_OVER || state == GameState.MENU) return;
    // ... manejo de teclas normal ...
    case KeyEvent.VK_P:
    case KeyEvent.VK_SPACE:
        if (state == GameState.PLAYING) {
            state = GameState.PAUSED;
            timer.stop();
        } else if (state == GameState.PAUSED) {
            state = GameState.PLAYING;
            timer.start();
        }
        repaint();
        break;
}

// EN initGame()
state = GameState.PLAYING;

// EN gameOver()
state = GameState.GAME_OVER;

// EN paintComponent() — pintar según estado
if (state == GameState.MENU) {
    drawCenteredText(g, "Press Start Game to begin", getHeight() / 2);
} else if (state == GameState.PAUSED) {
    // pintar snake, food, y texto PAUSED encima
} else if (state == GameState.GAME_OVER) {
    // pintar snake, food, y texto GAME OVER encima
}
