public Food(Snake snake, List<Node> obstacles) {
    boolean occupied = true;
    while (occupied) {
        row = (int) (Math.random() * Board.NUM_ROWS);
        col = (int) (Math.random() * Board.NUM_COLS);
        occupied = snake.contains(new Node(row, col));
        if (!occupied && obstacles != null) {
            for (Node obs : obstacles) {
                if (obs.getRow() == row && obs.getCol() == col) {
                    occupied = true;
                    break;
                }
            }
        }
    }
}
