// EN Board.createFood() — añadir posibilidad
public Food createFood() {
    Random r = new Random();
    int num = r.nextInt(6); // 0-5
    if (num == 0) {
        return new SpecialFood(snake, this);    // 1/6 = especial
    } else if (num == 1) {
        return new PoisonFood(snake);            // 1/6 = veneno
    } else {
        return new Food(snake);                  // 4/6 = normal
    }
}

// EN Board.tick() — tratar PoisonFood
if (snake.eats(food)) {
    if (food instanceof SpecialFood) {
        snake.incrementNodesToGrow(3);
        incrementer.incrementScore(20);
    } else if (food instanceof PoisonFood) {
        // Restar puntos y encoger
        incrementer.incrementScore(-5);
        snake.shrink(2); // quitar 2 nodos por la cola
    } else {
        snake.incrementNodesToGrow(1);
        incrementer.incrementScore(5);
    }
    food = createFood();
}

// EN Snake.java — nuevo método shrink
public void shrink(int nodes) {
    for (int i = 0; i < nodes && body.size() > 1; i++) {
        body.remove(body.size() - 1);
    }
}
