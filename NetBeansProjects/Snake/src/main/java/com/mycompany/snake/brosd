// NUEVA CLASE: HighScoreManager.java
package com.mycompany.snakeexam2;

import java.io.*;
import java.util.ArrayList;
import java.util.List;

public class HighScoreManager {
    private static final String FILE_PATH = "highscores.txt";

    // Guardar una entrada: nombre,puntuación
    public static void saveScore(String playerName, int score) {
        try (PrintWriter pw = new PrintWriter(new FileWriter(FILE_PATH, true))) {
            pw.println(playerName + "," + score);
        } catch (IOException e) {
            e.printStackTrace();
        }
    }

    // Cargar todas las puntuaciones
    public static List<String> loadScores() {
        List<String> scores = new ArrayList<>();
        File file = new File(FILE_PATH);
        if (!file.exists()) return scores;
        try (BufferedReader br = new BufferedReader(new FileReader(file))) {
            String line;
            while ((line = br.readLine()) != null) {
                scores.add(line); // formato: "nombre,puntuación"
            }
        } catch (IOException e) {
            e.printStackTrace();
        }
        return scores;
    }

    // Obtener el high score
    public static int getHighScore() {
        int max = 0;
        for (String entry : loadScores()) {
            try {
                int score = Integer.parseInt(entry.split(",")[1]);
                if (score > max) max = score;
            } catch (Exception ignored) {}
        }
        return max;
    }
}

// EN Board.gameOver() — guardar puntuación
