package com.mycompany.snakeexam2;

import java.io.*;

public class GameSaver {
    private static final String SAVE_FILE = "savegame.dat";

    public static void saveGame(Snake snake, int score, int level) {
        try (ObjectOutputStream oos = new ObjectOutputStream(
                new FileOutputStream(SAVE_FILE))) {
            oos.writeObject(snake);
            oos.writeInt(score);
            oos.writeInt(level);
        } catch (IOException e) {
            e.printStackTrace();
        }
    }

    public static Object[] loadGame() {
        try (ObjectInputStream ois = new ObjectInputStream(
                new FileInputStream(SAVE_FILE))) {
            Snake snake = (Snake) ois.readObject();
            int score = ois.readInt();
            int level = ois.readInt();
            return new Object[]{snake, score, level};
        } catch (Exception e) {
            return null; // No hay partida guardada
        }
    }
}

